# ─────────────────────────────────────────────────────────────────
# DC-Pickaxe Analytics 환경변수 설정
#
# ⚠️  이 파일(.env.example)은 깃허브에 올라가도 괜찮습니다.
#     실제 키/값을 채운 .env 파일은 절대 깃허브에 올리면 안 됩니다.
#
# 사용법:
#   1. 이 파일을 복사해서 .env 라는 이름으로 저장하세요.
#   2. 아래 각 항목에 실제 값을 채워 넣으세요.
# ─────────────────────────────────────────────────────────────────

# ── Google 서비스 계정 ────────────────────────────────────────────
# [로컬 개발용] 다운받은 JSON 파일을 이 프로젝트 폴더에 넣고 파일명을 아래에 적으세요.
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# [GitHub Actions / Streamlit Cloud용] JSON 파일 내용 전체를 한 줄 문자열로 붙여넣습니다.
# 로컬에서는 위의 FILE 방식을 쓰므로 이 항목은 비워도 됩니다.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── Google Sheets ─────────────────────────────────────────────────
# DC-Pickaxe가 게시글을 수집해 저장하는 마스터 시트의 URL
DC_PICKAXE_MASTER_SHEET_URL=https://docs.google.com/spreadsheets/d/여기에_마스터시트_ID/edit

# 분석 결과를 저장할 새 스프레드시트의 ID
# (URL에서 /d/ 뒤 ~ /edit 앞의 긴 문자열)
ANALYTICS_SPREADSHEET_ID=여기에_분석결과_시트_ID

# ── Gemini AI ─────────────────────────────────────────────────────
GEMINI_API_KEY=여기에_Gemini_API_키
GEMINI_MODEL=gemini-2.5-flash

# ── Notion ───────────────────────────────────────────────────────
# Notion 통합 토큰 (https://www.notion.so/my-integrations 에서 발급)
NOTION_TOKEN=여기에_Notion_인테그레이션_토큰

# 보고서를 쌓을 Notion 데이터베이스 ID
# URL: https://www.notion.so/[데이터베이스ID]?v=...
#      에서 ?v= 앞의 32자리 문자열
NOTION_DATABASE_ID=339fa327f286803da6d9f9f87da94df9
